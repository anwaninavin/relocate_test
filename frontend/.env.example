# Base URL of the deployed backend API (Express, on Render), e.g.:
# https://hostel-dpqg.onrender.com
VITE_API_URL=http://localhost:4000

# MSG91 "Login with OTP" widget — PUBLIC values (safe to ship in the frontend bundle), used at
# build time by src/lib/msg91.ts for passwordless mobile+OTP login. Reuse the SAME widget as
# the WhatsLocal project (don't create another); the widget's secret half is the backend's
# MSG91_AUTH_KEY. The Hostel domain must be added to this widget's allowed-domains whitelist in
# the MSG91 dashboard, or the widget script refuses to load.
VITE_MSG91_WIDGET_ID=3666786f316c313635323337
VITE_MSG91_TOKEN_AUTH=312759TRZYCE2x67e4f528P1
